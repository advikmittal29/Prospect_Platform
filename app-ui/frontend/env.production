# This file must exist when you run `npm run build` on the remote server
# (or in CI before deploying dist/).
#
# The URL here is what the BROWSER uses — i.e. the public address of your IIS site.
# Because the web.config above rewrites /api/* → FastAPI, the browser just hits
# the same host:port as the UI itself.
VITE_API_BASE_URL=http://localhost:8000

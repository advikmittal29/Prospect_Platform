# =============================================================================
# prospect_platform environment configuration
# Copy this file to .env and fill values for your machine.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (SQL Server via pyodbc)
# -----------------------------------------------------------------------------
# Windows auth example:
DB_URL=mssql+pyodbc://@localhost/ProspectDB?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes&TrustServerCertificate=yes

# SQL auth example:
# DB_URL=mssql+pyodbc://sa:YourStrongPassword@localhost/ProspectDB?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

DB_ECHO=false
DB_POOL_SIZE=5
DB_POOL_RECYCLE=1800

# -----------------------------------------------------------------------------
# Job ingestion settings
# -----------------------------------------------------------------------------
INGEST_KEYWORDS=AI Engineer,ML Engineer,Data Scientist,Python Developer
INGEST_LOCATION=
INGEST_MAX_JOB_AGE_DAYS=7
INGEST_MAX_JOBS_PER_KEYWORD=50

# -----------------------------------------------------------------------------
# Naukri scraper browser settings (Playwright Chromium)
# -----------------------------------------------------------------------------
BROWSER_HEADLESS=true
BROWSER_FAST_MODE=true
BROWSER_NAV_TIMEOUT_MS=15000
BROWSER_ACTION_TIMEOUT_MS=6000
BROWSER_SCROLL_PAUSE_SEC=0.25
BROWSER_LISTING_SCROLL_ROUNDS=6
BROWSER_POLITE_SLEEP_SEC=0.1
BROWSER_DETAIL_PAGE_DELAY_SEC=0.4
BROWSER_VIEWPORT_W=1440
BROWSER_VIEWPORT_H=900

# -----------------------------------------------------------------------------
# LinkedIn research browser settings (Chrome CDP)
# -----------------------------------------------------------------------------
CHROME_CDP_ATTACH=true
CHROME_CDP_URL=http://127.0.0.1:9223
CHROME_EXE=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_USER_DATA_DIR=C:\Users\Public\chrome-cdp-profile
CHROME_HEADLESS=false
CHROME_STARTUP_WAIT_SEC=2.5
CHROME_NAV_TIMEOUT_MS=30000
CHROME_ACTION_TIMEOUT_MS=8000
CHROME_RECOVERY_ATTEMPTS=2

# -----------------------------------------------------------------------------
# LLM settings
# -----------------------------------------------------------------------------
# Supported providers: openai | gemini | groq
LLM_PROVIDER=openai

# Examples:
# OpenAI: gpt-4o-mini
# Gemini: gemini-2.5-flash
# Groq: llama-3.3-70b-versatile
LLM_MODEL=gpt-4o-mini

# Use the API key for the selected provider.
LLM_API_KEY=

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_TIMEOUT_SEC=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_SEC=2.0
PROMPT_DIR=
PROMPT_PROFILE_FILE=

# -----------------------------------------------------------------------------
# Multi-agent runtime settings
# -----------------------------------------------------------------------------
AGENT_DEFAULT_KEY=default-staffing
# deterministic | autonomous
AGENT_RUNTIME_MODE=deterministic
AGENT_AUTONOMOUS_ALLOW_FALLBACK=true
AGENT_MAX_TOOL_CALLS_PER_RUN=50
AGENT_MAX_RUN_MINUTES=90

# -----------------------------------------------------------------------------
# Research pipeline settings
# -----------------------------------------------------------------------------
RESEARCH_BATCH_SIZE=10
RESEARCH_MAX_PROSPECTS=20
RESEARCH_MAX_PROFILES_ASSESS=8
RESEARCH_MIN_COMPANY_CONF=70.0

# -----------------------------------------------------------------------------
# Outreach identity settings
# -----------------------------------------------------------------------------
OUTREACH_RECRUITER_NAME=Alex
OUTREACH_AGENCY_NAME=RecruitPro
# Optional: linkedin_connect | linkedin_message | email
# Keep empty to use auto-selection logic.
OUTREACH_FORCE_CHANNEL=

# -----------------------------------------------------------------------------
# Outreach test-mode email dispatch settings
# -----------------------------------------------------------------------------
# When enabled, generated outreach messages are also sent to a fixed test inbox.
OUTREACH_TEST_MODE_ENABLED=false
OUTREACH_TEST_RECIPIENT_EMAIL=
OUTREACH_TEST_SUBJECT_PREFIX=[Outreach-Test]

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SEC=20

# -----------------------------------------------------------------------------
# Candidate hunt pipeline settings
# -----------------------------------------------------------------------------
CANDIDATE_HUNT_ENABLED=true
CANDIDATE_HUNT_JOB_BATCH_SIZE=10
CANDIDATE_HUNT_MAX_PAGES_PER_QUERY=5
CANDIDATE_HUNT_MAX_CANDIDATES_PER_JOB=60
CANDIDATE_HUNT_MAX_PROFILES_TO_ENRICH=20
CANDIDATE_HUNT_MAX_QUERY_VARIANTS=8
CANDIDATE_HUNT_MIN_CARD_RELEVANCE_SCORE=30
CANDIDATE_HUNT_PROFILE_RETRY_LIMIT=2
CANDIDATE_HUNT_NAV_TIMEOUT_MS=25000
CANDIDATE_HUNT_PAGE_SETTLE_MS=900
CANDIDATE_HUNT_POLITE_DELAY_SEC=0.5
CANDIDATE_HUNT_LOCATION_FALLBACK=
CANDIDATE_HUNT_INCLUDE_COMPANY_IN_QUERY=false
CANDIDATE_HUNT_INCLUDE_NEGATIVE_KEYWORDS=true

# -----------------------------------------------------------------------------
# App UI (app-ui/backend + app-ui/frontend)
# -----------------------------------------------------------------------------
APP_UI_ADMIN_USER=admin
APP_UI_ADMIN_PASS=admin123
APP_UI_JWT_SECRET=replace-with-long-random-secret
APP_UI_JWT_EXPIRE_HOURS=12
APP_UI_ALLOWED_ORIGINS=http://127.0.0.1:5174,http://localhost:5174
# Optional override for subprocess execution from UI trigger actions:
# APP_UI_PYTHON=C:\Users\ankit\AgenticApps\demo01_pipeline\prospect_platform\.venv\Scripts\python.exe
